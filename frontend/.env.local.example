# Copy to .env.local and fill in. Never commit .env.local.
FASTAPI_URL=http://localhost:8000
# Must match the FastAPI backend's API_KEY (required — no default).
API_KEY=
# Secret used to sign the session cookie (required — no default).
COOKIE_SECRET=
# Single demo account. Defaults to demo/demo if unset.
AUTH_USERNAME=demo
AUTH_PASSWORD=demo
